{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cursor Agent Traffic Light",
  "version": "0.1.0",
  "identifier": "com.cursor.agent-traffic-light",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Agent Traffic Light",
        "width": 64,
        "height": 204,
        "minWidth": 64,
        "maxWidth": 64,
        "minHeight": 204,
        "maxHeight": 204,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "center": false,
        "x": 48,
        "y": 120
      },
      {
        "label": "settings",
        "title": "设置",
        "width": 360,
        "height": 420,
        "minWidth": 360,
        "minHeight": 420,
        "resizable": false,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
